# Backend API base, including the /v1 prefix.
NEXT_PUBLIC_API_URL=https://kiba-1.onrender.com/v1

# Legal pages linked from the A2P consent disclosure on the signup form
# (Step4Contact). They live on the marketing site, not this app.
#
# A carrier reviewer WILL follow both links during A2P campaign review — if
# either 404s the campaign is rejected. Confirm both are live before submitting.
NEXT_PUBLIC_SMS_TERMS_URL=https://usekiba.ai/sms-terms
NEXT_PUBLIC_PRIVACY_URL=https://usekiba.ai/privacy

# Price label on the onboarding trial summary. Keep in sync with the backend's
# STRIPE_PRICE_DISPLAY — if they drift, the signup page promises one price and
# the card gets charged another.
NEXT_PUBLIC_PRICE_DISPLAY=$9.99/mo
