# App
NODE_ENV=development
PORT=3000
# Public-facing HTTPS URL for the backend — used for Twilio webhook signature validation
APP_BASE_URL=https://api.ryke.ai
# Frontend origin for CORS allowlist
FRONTEND_URL=https://ryke.ai
SESSION_TIMEOUT_HOURS=4

# Internal admin API key — must be at least 32 chars — guards data export/delete & crisis resolution
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=change_me_generate_with_openssl_rand_hex_32

# Database
DATABASE_URL=postgresql://rykeai:rykeai_local@localhost:5432/rykeai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=   # set in production

# Twilio (SMS/MMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15550001234

# SendBlue (iMessage) — optional; SMS-only mode if not set
SENDBLUE_API_KEY_ID=your_sendblue_api_key_id
SENDBLUE_API_SECRET_KEY=your_sendblue_api_secret_key
SENDBLUE_SENDING_NUMBER=+15550001234

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_INDIVIDUAL=price_xxx
STRIPE_PRICE_ID_COACH_PRO=price_xxx
STRIPE_PRICE_ID_COACH_ELITE=price_xxx
STRIPE_TRIAL_DAYS=7
# Human price label KIBA quotes in SMS/intake copy. MUST match the real amount
# on STRIPE_PRICE_ID_INDIVIDUAL (else the bot promises one price, Stripe charges
# another). Defaults to $20/month if unset.
STRIPE_PRICE_DISPLAY=$20/month

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxx
AI_MODEL=claude-haiku-4-5-20251001
# AI_MODEL=claude-sonnet-4-6   # override for higher accuracy
# Warn-only ceiling (input+output tokens) for flagging unexpectedly expensive
# LLM turns. Default 20000; lower it to investigate cost, raise to silence.
# TOKEN_BUDGET_WARN_TOKENS=20000

# Retention: one-time "pin our chat" how-to sent right after a user subscribes.
# Can be an image, GIF, or VIDEO — must be a public HTTPS URL SendBlue/Twilio can
# fetch (e.g. a file in the frontend's public/ folder or a CDN). Leave unset to
# disable entirely. PIN_CHAT_MEDIA_URL is preferred; PIN_CHAT_IMAGE_URL still works
# as a fallback. NOTE: iMessage handles video natively, but Android/MMS (Twilio)
# caps size — keep it a short GIF or a compressed <~1MB mp4 for cross-platform.
# PIN_CHAT_MEDIA_URL=https://kiba-blond.vercel.app/pin-chat.mp4

# Crisis Detection — REQUIRED; app will not start without these
CRISIS_CONFIDENCE_THRESHOLD=0.65
CRISIS_COACH_ALERT_EMAIL=coach@ryke.ai
CRISIS_COACH_ALERT_PHONE=+15550009999

# Email (for coach alerts)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@ryke.ai
SMTP_PASS=your_smtp_password
SMTP_FROM=RYKE AI Alerts <alerts@ryke.ai>
