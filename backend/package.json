{
  "name": "kiba-backend",
  "version": "0.1.0",
  "description": "Kiba AI — NestJS backend",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"{src,tests}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration --runInBand",
    "test:contract": "jest --testPathPattern=contract --runInBand",
    "test:all": "jest --runInBand",
    "test:cov": "jest --coverage",
    "migration:run": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli migration:run -d src/data/data-source.ts",
    "migration:revert": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli migration:revert -d src/data/data-source.ts",
    "migration:generate": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli migration:generate -d src/data/data-source.ts",
    "health:check": "node -e \"fetch('http://localhost:'+(process.env.PORT||3000)+'/health').then(r=>r.json()).then(j=>{console.log(JSON.stringify(j,null,2));process.exit(j.status==='ok'?0:1);}).catch(e=>{console.error('health check failed:',e.message);process.exit(2);})\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.8.4",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "heic-convert": "^2.1.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "joi": "^17.13.3",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0",
    "twilio": "^5.4.5",
    "typeorm": "^0.3.20",
    "undici": "^8.2.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bull": "^4.10.0",
    "@types/express": "^5.0.1",
    "@types/heic-convert": "^2.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.14",
    "@types/nodemailer": "^6.4.17",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src/",
      "<rootDir>/tests/"
    ]
  }
}
